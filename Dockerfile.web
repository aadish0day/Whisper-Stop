# ── deps ──────────────────────────────────────────────────────────────────────
# Use Debian (glibc) not Alpine (musl) — the lockfile was generated on a glibc
# host so @rollup/rollup-linux-x64-gnu is present but the musl variant is not.
FROM node:24-slim AS deps
RUN corepack enable && corepack prepare pnpm@10 --activate
WORKDIR /app

# Copy ALL workspace package.json files — pnpm-workspace.yaml declares
# apps/*, packages/*, and scripts as members; all must be present or
# `pnpm install` fails on missing workspace packages.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY packages/api-client-react/package.json packages/api-client-react/
COPY packages/api-zod/package.json          packages/api-zod/
COPY packages/api-spec/package.json         packages/api-spec/
COPY packages/db/package.json               packages/db/
COPY apps/web/package.json                  apps/web/
COPY apps/api/package.json                  apps/api/
COPY scripts/package.json                   scripts/

RUN pnpm install --no-frozen-lockfile

# ── dev server ────────────────────────────────────────────────────────────────
FROM deps AS dev
WORKDIR /app

COPY tsconfig.base.json tsconfig.json ./
COPY packages/ packages/
COPY attached_assets/ attached_assets/
COPY apps/web/ apps/web/

EXPOSE 5173
ENV NODE_ENV=development

CMD ["pnpm", "--filter", "@workspace/web", "run", "dev"]
