# ── deps ──────────────────────────────────────────────────────────────────────
# Use Debian (glibc) not Alpine (musl) — the lockfile was generated on a glibc
# host so @rollup/rollup-linux-x64-gnu is present but the musl variant is not.
FROM node:24-slim AS deps
RUN corepack enable && corepack prepare pnpm@10 --activate
WORKDIR /app

# Copy ALL workspace package.json files — pnpm-workspace.yaml declares
# artifacts/*, lib/*, and scripts as members; all must be present or
# `pnpm install` fails on missing workspace packages.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY lib/api-client-react/package.json  lib/api-client-react/
COPY lib/api-zod/package.json           lib/api-zod/
COPY lib/api-spec/package.json          lib/api-spec/
COPY lib/db/package.json                lib/db/
COPY artifacts/whisperstop/package.json    artifacts/whisperstop/
COPY artifacts/api-server/package.json     artifacts/api-server/
COPY artifacts/mockup-sandbox/package.json artifacts/mockup-sandbox/
COPY scripts/package.json               scripts/

# --no-frozen-lockfile lets pnpm add platform-specific optional deps
# (e.g. @rollup/rollup-linux-x64-musl) missing from a lockfile generated
# on a non-musl host.
RUN pnpm install --no-frozen-lockfile

# ── dev server ────────────────────────────────────────────────────────────────
FROM deps AS dev
WORKDIR /app

COPY tsconfig.base.json tsconfig.json ./
COPY lib/   lib/
COPY attached_assets/ attached_assets/
COPY artifacts/whisperstop/ artifacts/whisperstop/

EXPOSE 5173
ENV NODE_ENV=development

CMD ["pnpm", "--filter", "@workspace/whisperstop", "run", "dev"]
